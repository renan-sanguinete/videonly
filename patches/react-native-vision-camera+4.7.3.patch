+private fun configureRecorderAudio(recorder: Recorder.Builder, audioConfig: CameraConfiguration.Audio) {
+  try {
+    val mediaSpecField = Recorder.Builder::class.java.getDeclaredField("mMediaSpecBuilder")
+    mediaSpecField.isAccessible = true
+    val mediaSpecBuilder = mediaSpecField.get(recorder)
+    val configureAudioMethod =
+      mediaSpecBuilder.javaClass.methods.firstOrNull { method ->
+        method.name == "configureAudio" && method.parameterTypes.size == 1
+      } ?: return
+
+    configureAudioMethod.invoke(mediaSpecBuilder, Consumer<AudioSpec.Builder> { builder ->
+      audioConfig.bitRate?.let { builder.setBitrate(Range(it, it)) }
+      audioConfig.sampleRate?.let { builder.setSampleRate(Range(it, it)) }
+      audioConfig.channelCount?.let { channels ->
+        val cameraXChannels =
+          when (channels) {
+            1 -> AudioSpec.CHANNEL_COUNT_MONO
+            2 -> AudioSpec.CHANNEL_COUNT_STEREO
+            else -> null
+          }
+        cameraXChannels?.let { builder.setChannelCount(it) }
+      }
+    })
+  } catch (error: Throwable) {
+    Log.w(CameraSession.TAG, "Failed to apply custom audio settings, falling back to defaults.", error)
+  }
+}
